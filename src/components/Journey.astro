---
import { ExperienceConf } from "@confs";

const months: string[] = [
  "Jan",
  "Feb",
  "Mar",
  "Apr",
  "May",
  "Jun",
  "Jul",
  "Aug",
  "Sep",
  "Oct",
  "Nov",
  "Dec",
];

function getDate(date?: Time) {
  if (!date) return "Present";
  return months[date.month - 1] + " " + date.year;
}
---

<section class="journey" id="career">
  <div class="journey-container">
    {
      ExperienceConf.map((exp, idx) => (
        <div
          class:list={[
            "timeline-block",
            `timeline-block-${idx & 1 ? "right" : "left"}`,
            "reveal",
            `reveal-delay-${(idx % 4) + 1}`,
          ]}
        >
          <div class:list={["marker", idx === 0 && "marker-current"]} />
          <div class="timeline-content">
            <h3 class="title">{exp.title}</h3>
            <section class="workplace">
              <div class="org-name">
                <i class="cil-library-building icon" />
                <span>{exp.org}</span>
                <a href={exp.site} target="_blank" class="org-site">
                  <i class="cil-external-link" />
                </a>
              </div>
              <div class="duration">
                <i class="cil-calendar icon" />
                <span>
                  {getDate(exp.duration.start) +
                    " - " +
                    getDate(exp.duration.end)}
                </span>
              </div>
            </section>
            <section class="location">
              <i class="cil-location-pin icon" />
              <span>{exp.location}</span>
            </section>
            <ul>
              {exp.description.map((d) => (
                <li class="description">{d}</li>
              ))}
            </ul>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style lang="scss">
  @import "../styles/media.scss";

  .journey {
    font-family: var(--font-family-inria);
    display: flex;
    justify-content: center;
  }
  .journey-container {
    padding: 20px 32px 40px;
    position: relative;
    overflow: hidden;
    max-width: 1080px;
    &:before {
      content: "";
      position: absolute;
      top: 15px;
      left: 50%;
      margin-left: -1px;
      width: 2px;
      height: 97%;
      background: linear-gradient(
        to bottom,
        var(--accent-contrast),
        var(--accent-dark),
        transparent
      );
      z-index: 1;
      @include medium_device {
        left: 30px;
      }
    }
    @include medium_device {
      padding: 20px 20px 40px;
    }
  }
  .timeline-block {
    width: calc(50% + 8px);
    display: flex;
    gap: 12px;
    clear: both;
    @include medium_device {
      width: 100%;
      margin-bottom: 30px;
    }
    &-right {
      float: right;
      @include medium_device {
        float: none;
      }
    }
    &-left {
      float: left;
      direction: rtl;
      @include medium_device {
        float: none;
        direction: ltr;
      }
    }

    .marker {
      width: 14px;
      height: 14px;
      min-width: 14px;
      border-radius: 50%;
      border: 2px solid rgba(255, 255, 255, 0.15);
      background: var(--accent-dark);
      margin-top: 16px;
      z-index: 9999;
      transition: all var(--transition-smooth);
      &-current {
        background: var(--accent-contrast);
        animation: pulse 2s ease-in-out infinite;
        box-shadow: 0 0 12px var(--accent-glow);
      }
    }
    .timeline-content {
      width: 95%;
      padding: 20px;
      background: var(--background-glass);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      direction: ltr;
      transition: all var(--transition-smooth);
      &:hover {
        border-color: rgba(255, 255, 255, 0.12);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
        transform: translateY(-2px);
      }
      .title {
        font-size: var(--text-lg);
        color: var(--light-mild);
        @include medium_device {
          font-size: var(--text-md);
        }
      }
      .workplace {
        display: flex;
        gap: 4px 12px;
        color: var(--light-main);
        margin: 12px 0 0;
        flex-wrap: wrap;
      }
      .icon {
        color: var(--accent-contrast);
      }
      .org-name,
      .duration {
        font-family: var(--font-family-inria);
        display: flex;
        align-items: baseline;
        gap: 8px;
        font-size: var(--text-sm);
      }
      .org-site {
        color: var(--light-main);
        text-decoration: none;
        transition: color var(--transition-fast);
        &:hover {
          color: var(--accent-contrast);
        }
      }
      .org-site {
        color: var(--light-main);
        text-decoration: none;
        &:hover {
          color: var(--accent-contrast);
        }
      }
      .location {
        color: var(--light-grey);
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 4px;
        font-size: var(--text-sm);
      }
      ul {
        margin-left: 18px;
        margin-top: 8px;
        .description {
          font-size: var(--text-sm);
          line-height: 1.7;
          word-spacing: 1px;
          color: var(--light-grey);
          margin: 4px 0 0;
          font-family: var(--font-family-inria-regular);
        }
      }
    }
  }
</style>
