---
import Card from "@common-components/Card.astro";
import Tag from "@common-components/Tag.astro";
import Container from "@common-components/Container.astro";

import { ProjectsConf } from "@confs";
---

<section id="projects">
  <Container>
    <Fragment slot="header">
      My&nbsp;<span class="highlight">Projects</span>
    </Fragment>
    <Fragment slot="subheader"
    >Things I created while learning and solving problems</Fragment
    >
    <div class="project-container">
      <div class="projects">
        {
          ProjectsConf.map((project: Project, idx: number) => (
            <div class:list={["reveal", `reveal-delay-${(idx % 3) + 1}`]}>
              <Card>
                <img
                  class="cover-image"
                  slot="cover"
                  src={project.cover}
                  alt={project.title}
                />
                <div slot="details" class="details">
                  <div class="project-title">{project.title}</div>
                  <p class="project-description" set:html={project.description} />
                  <div class="project-tags">
                    {project.tags.map((tag) => (
                      <Tag class:list={[""]}>{tag}</Tag>
                    ))}
                  </div>
                  <div class="project-actions">
                    {!!project.git && (
                      <a class="action" href={project.git} target="_blank">
                        <i class="cib-github" />
                        <span>Source</span>
                      </a>
                    )}
                    {!!project.live && (
                      <a class="action action-live" href={project.live} target="_blank">
                        <i class="cil-external-link" />
                        <span>Live</span>
                      </a>
                    )}
                  </div>
                </div>
              </Card>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>

<style lang="scss">
  @import "../styles/media.scss";

  .project-container {
    padding: 0 32px;
    display: flex;
    justify-content: center;
    @include medium_device {
      padding: 0 20px;
    }
  }
  .projects {
    display: grid;
    margin: 0 16px;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 1080px;
    @include medium_device {
      grid-template-columns: 1fr;
      margin: 0;
    }
    .cover-image {
      height: 100%;
      width: 100%;
      border-radius: 20px 20px 0 0;
      object-fit: cover;
      filter: brightness(0.85);
      transform: scale(1.01);
      transition: filter var(--transition-smooth), transform var(--transition-smooth);
    }
    :global(.card:hover) .cover-image {
      filter: brightness(1);
      transform: scale(1.06);
    }
    .details {
      color: var(--light-main);
      display: flex;
      flex-direction: column;
      .project {
        &-title {
          font-family: var(--font-family-inria);
          font-size: var(--text-xl);
          font-weight: 700;
          background: var(--gradient-highlight);
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          margin-bottom: 4px;
        }
        &-description {
          font-family: var(--font-family-inria-regular);
          font-size: var(--text-base);
          margin: 12px 0 20px;
          color: var(--light-mild);
          line-height: 1.6;
          flex-grow: 1;
        }
        &-tags {
          display: flex;
          flex-wrap: wrap;
          gap: 8px 10px;
          margin-bottom: 20px;
        }
        &-actions {
          display: flex;
          gap: 12px;
          margin-top: auto;
          .action {
            background: var(--background-glass);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            padding: 10px 20px;
            border-radius: 12px;
            color: var(--light-main);
            text-decoration: none;
            display: flex;
            gap: 8px;
            align-items: center;
            font-family: var(--font-family-inria);
            font-size: var(--text-sm);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all var(--transition-fast);
            &:hover {
              background: var(--gradient-subtle);
              border-color: rgba(218, 65, 103, 0.5);
              transform: translateY(-2px);
              box-shadow: 0 4px 15px rgba(218, 65, 103, 0.2);
            }
            &-live {
              background: var(--gradient-highlight);
              border-color: transparent;
              &:hover {
                box-shadow: 0 6px 20px rgba(218, 65, 103, 0.4);
                transform: translateY(-2px) scale(1.02);
              }
            }
          }
        }
      }
    }
  }
</style>
